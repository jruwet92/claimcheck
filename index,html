<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Health Claim Evaluator</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 15px;
    color: #111;
    background: #fff;
    padding: 48px 24px;
  }

  .wrap {
    max-width: 560px;
    margin: 0 auto;
  }

  h1 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 32px;
  }

  .field {
    margin-bottom: 20px;
  }

  label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: #555;
    margin-bottom: 5px;
  }

  input[type="text"], textarea {
    width: 100%;
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 9px 12px;
    font-family: inherit;
    font-size: 15px;
    color: #111;
    background: #fafafa;
    transition: border-color 0.15s;
    resize: vertical;
  }

  input[type="text"]:focus, textarea:focus {
    outline: none;
    border-color: #999;
    background: #fff;
  }

  textarea { min-height: 90px; }

  .claims-list { display: flex; flex-direction: column; gap: 8px; }

  .claim-row { display: flex; gap: 6px; }
  .claim-row input { flex: 1; }

  .btn-remove {
    background: none;
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 0 10px;
    cursor: pointer;
    color: #aaa;
    font-size: 18px;
    transition: color 0.15s, border-color 0.15s;
  }

  .btn-remove:hover { color: #e00; border-color: #e00; }

  .btn-add {
    margin-top: 8px;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    font-size: 13px;
    color: #666;
    cursor: pointer;
    text-decoration: underline;
  }

  .btn-add:hover { color: #111; }

  hr {
    border: none;
    border-top: 1px solid #eee;
    margin: 28px 0;
  }

  .btn-submit {
    background: #111;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 11px 24px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-submit:hover { background: #333; }
  .btn-submit:disabled { opacity: 0.4; cursor: not-allowed; }

  .status {
    display: none;
    margin-top: 12px;
    font-size: 13px;
  }
  .status.success { display: block; color: #1a7a3a; }
  .status.error   { display: block; color: #c00; }
</style>
</head>
<body>
<div class="wrap">
  <h1>Health Claim Evaluator</h1>

  <form id="form">
    <div class="field">
      <label for="email">Your email</label>
      <input type="text" id="email" placeholder="you@example.com" required>
    </div>

    <div class="field">
      <label for="productName">Product name</label>
      <input type="text" id="productName" placeholder="e.g. NutriBoost Capsules" required>
    </div>

    <div class="field">
      <label for="ingredients">Ingredient list & quantity</label>
      <textarea id="ingredients" placeholder="Vitamin C — 500mg&#10;Zinc — 10mg&#10;…" required></textarea>
    </div>

    <hr>

    <div class="field">
      <label>Health claims</label>
      <div class="claims-list" id="claimsList">
        <div class="claim-row">
          <input type="text" placeholder="e.g. Supports immune function" required>
        </div>
      </div>
      <button type="button" class="btn-add" onclick="addClaim()">+ Add another claim</button>
    </div>

    <button type="submit" class="btn-submit" id="submitBtn">Send for evaluation</button>
    <div class="status" id="status"></div>
  </form>
</div>

<script>
  function addClaim() {
    const list = document.getElementById('claimsList');
    const row = document.createElement('div');
    row.className = 'claim-row';
    row.innerHTML = `
      <input type="text" placeholder="e.g. Contributes to normal energy metabolism" required>
      <button type="button" class="btn-remove" onclick="this.closest('.claim-row').remove()">×</button>
    `;
    list.appendChild(row);
    row.querySelector('input').focus();
  }

  document.getElementById('form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    const status = document.getElementById('status');
    status.className = 'status';

    const payload = {
      email: document.getElementById('email').value.trim(),
      productName: document.getElementById('productName').value.trim(),
      ingredients: document.getElementById('ingredients').value.trim(),
      healthClaims: [...document.querySelectorAll('#claimsList input')]
        .map(i => i.value.trim()).filter(Boolean)
    };

    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      await fetch('https://hook.eu2.make.com/e3qtv2hjk7gjt8kj1e9etswc4v41wlhe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      status.className = 'status success';
      status.textContent = '✓ Submitted successfully.';
      e.target.reset();
      document.getElementById('claimsList').innerHTML = `
        <div class="claim-row">
          <input type="text" placeholder="e.g. Supports immune function" required>
        </div>`;
    } catch {
      status.className = 'status error';
      status.textContent = '✗ Something went wrong. Please try again.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send for evaluation';
    }
  });
</script>
</body>
</html>
